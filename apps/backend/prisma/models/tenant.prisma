model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships    Membership[]
  customers      Customer[]
  services       Service[]
  appointments   Appointment[]
  portfolioPosts PortfolioPost[]

  @@map("tenant")
}
