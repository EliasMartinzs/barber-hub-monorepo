model PortfolioPost {
  id          String   @id @default(uuid())
  tenantId    String
  barberId    String // membershipId
  imageUrl    String
  description String?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  barber Membership @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([barberId])
}
