model Tenant {
  id             String          @id @default(uuid())
  name           String
  slug           String          @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  appointments   Appointment[]
  memberships    Membership[]
  portfolioPosts PortfolioPost[]
  services       Service[]

  @@map("tenant")
}
