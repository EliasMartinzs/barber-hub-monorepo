model Appointment {
  id         String               @id @default(uuid())
  tenantId   String
  customerId String
  barberId   String
  startAt    DateTime
  endAt      DateTime
  status     AppointmentStatus    @default(SCHEDULED)
  totalPrice Decimal              @db.Decimal(10, 2)
  notes      String?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  barber     Membership           @relation("barber", fields: [barberId], references: [id])
  customer   Membership           @relation("customer", fields: [customerId], references: [id])
  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  services   AppointmentService[]

  @@index([tenantId])
  @@index([barberId])
  @@index([customerId])
  @@index([startAt])
}
