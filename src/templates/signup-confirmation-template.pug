doctype html
html(lang="pt-BR")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Confirme seu e-mail

  body(style="margin:0; padding:0; background:#f4f4f7; font-family:Arial, sans-serif;")
    table(width="100%" cellpadding="0" cellspacing="0" style="background:#f4f4f7; padding:20px 0;")
      tr
        td(align="center")
          table(width="600" cellpadding="0" cellspacing="0" style="background:#ffffff; border-radius:8px; padding:40px;")

            // Título
            tr
              td(style="text-align:center; padding-bottom:20px;")
                h1(style="margin:0; font-size:24px; color:#333;") Confirme seu e-mail

            // Saudação
            tr
              td(style="font-size:16px; color:#555; padding-bottom:20px;")
                | Olá, #{name}!

            // Mensagem
            tr
              td(style="font-size:16px; color:#555; padding-bottom:20px; line-height:1.5;")
                | Obrigado por se cadastrar! Para ativar sua conta, confirme seu e-mail clicando no botão abaixo.

            // Botão
            tr
              td(align="center" style="padding:30px 0;")
                a(
                  href=url
                  style="background:#4f46e5; color:#ffffff; text-decoration:none; padding:12px 24px; border-radius:6px; display:inline-block; font-size:16px;"
                ) Confirmar e-mail

            // Link alternativo
            tr
              td(style="font-size:14px; color:#888; padding-top:20px; word-break:break-all;")
                | Se o botão não funcionar, copie e cole este link no seu navegador:
                br
                a(href=url style="color:#4f46e5;")= url

            // Rodapé
            tr
              td(style="font-size:12px; color:#aaa; padding-top:40px; text-align:center;")
                | Se você não criou uma conta, pode ignorar este e-mail com segurança.